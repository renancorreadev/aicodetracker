{
  "name": "aicodetracker",
  "displayName": "AICodeTracker",
  "description": "Track what AI wrote. Review what matters.",
  "version": "0.1.0",
  "publisher": "renancorrea",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aicodetracker.toggle",
        "title": "AICodeTracker: Toggle Highlights"
      }
    ],
    "configuration": {
      "title": "AICodeTracker",
      "properties": {
        "aicodetracker.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable AICodeTracker highlights"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
